rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ──────────────────────────────────────────────────────────────
    // User must be signed in AND their email must exist in the whitelist.
    function isWhitelisted() {
      return request.auth != null
          && exists(/databases/$(database)/documents/system/access/approved/$(request.auth.token.email.lower()));
    }

    // User must own the document (uid matches path segment).
    function isOwner(uid) {
      return request.auth != null && request.auth.uid == uid;
    }

    // ── Whitelist ─────────────────────────────────────────────────────────────
    // Users may read only their own whitelist entry (to check access on login).
    // Writes go through the Admin SDK server only — never from the client.
    match /system/access/approved/{email} {
      allow read:  if request.auth != null && request.auth.token.email.lower() == email;
      allow write: if false;
    }

    // ── App data — scoped under artifacts/jdinjax-console/users/{userId} ─────
    // Listings subtree: artifacts/jdinjax-console/users/{uid}/listings/{doc}
    match /artifacts/jdinjax-console/users/{userId}/listings/{document=**} {
      allow read, write: if isOwner(userId) && isWhitelisted();
    }

    // Config/settings: artifacts/jdinjax-console/users/{uid}/config/{doc}
    match /artifacts/jdinjax-console/users/{userId}/config/{document=**} {
      allow read, write: if isOwner(userId) && isWhitelisted();
    }

    // Sourcing targets: artifacts/jdinjax-console/users/{uid}/targets/{doc}
    match /artifacts/jdinjax-console/users/{userId}/targets/{document=**} {
      allow read, write: if isOwner(userId) && isWhitelisted();
    }

    // ── Catch-all — deny everything else ─────────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
