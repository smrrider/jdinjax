# ─────────────────────────────────────────────────────────────────────────────
# JDINJAX eBay Listing Pro Console — Environment Variables
# Version: 3.4.7
# ─────────────────────────────────────────────────────────────────────────────
#
# LOCAL SETUP:
#   1. Copy this file:  copy .env.example .env  (Windows)
#   2. Fill in all values below
#   3. Run: npm start
#
# RAILWAY SETUP:
#   Add each variable below in your Railway project → Variables tab.
#   Do NOT upload the .env file — it is blocked by .gitignore.
#
# ─────────────────────────────────────────────────────────────────────────────

# ── Gemini AI ─────────────────────────────────────────────────────────────────
# Get your key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=PASTE_YOUR_GEMINI_KEY_HERE

# ── Firebase ──────────────────────────────────────────────────────────────────
# Get these from: Firebase Console → Project Settings → General → Your Apps
FIREBASE_API_KEY=PASTE_YOUR_FIREBASE_API_KEY_HERE
FIREBASE_AUTH_DOMAIN=jdinjax-console.firebaseapp.com
FIREBASE_PROJECT_ID=jdinjax-console
FIREBASE_STORAGE_BUCKET=jdinjax-console.firebasestorage.app
FIREBASE_MESSAGING_SENDER_ID=PASTE_YOUR_SENDER_ID_HERE
FIREBASE_APP_ID=PASTE_YOUR_APP_ID_HERE
FIREBASE_MEASUREMENT_ID=PASTE_YOUR_MEASUREMENT_ID_HERE

# ── Cloudinary ────────────────────────────────────────────────────────────────
# Get these from: cloudinary.com → Dashboard
CLOUDINARY_CLOUD_NAME=daeb6pcxf
CLOUDINARY_UPLOAD_PRESET=jdinjax_unsigned

# ── Server ────────────────────────────────────────────────────────────────────
# Railway assigns PORT automatically — only set this for local use if needed
# PORT=3001
