# ─────────────────────────────────────────────────────────────────────────────
# JDINJAX eBay Listing Pro Console — Proxy Environment Config
# ─────────────────────────────────────────────────────────────────────────────
#
# SETUP INSTRUCTIONS:
#   1. Copy this file:  copy .env.example .env   (Windows)
#                       cp .env.example .env      (Mac/Linux)
#   2. Paste your Gemini API key below.
#   3. NEVER commit the .env file to git. It is already in .gitignore.
#
# Get your key at: https://aistudio.google.com/app/apikey
# ─────────────────────────────────────────────────────────────────────────────

GEMINI_API_KEY=PASTE_YOUR_KEY_HERE

# Optional: Change the port if 3001 is in use on your machine
PORT=3001
